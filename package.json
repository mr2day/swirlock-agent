{
  "name": "swirlock-agent",
  "displayName": "Swirlock Agent",
  "description": "Local autonomous coding agent backed by swirlock-llm-host.",
  "version": "0.0.4",
  "publisher": "swirlock",
  "repository": {
    "type": "git",
    "url": "https://github.com/mr2day/swirlock-agent.git"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "swirlock-agent",
          "title": "Swirlock Agent",
          "icon": "resources/swirlock.svg"
        }
      ]
    },
    "views": {
      "swirlock-agent": [
        {
          "type": "tree",
          "id": "swirlock-agent.launcher",
          "name": "Swirlock",
          "icon": "resources/swirlock.svg",
          "contextualTitle": "Swirlock Agent"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "swirlock-agent.launcher",
        "contents": "The Swirlock agent runs in an editor tab so you can keep it next to your code.\n\n[Open Swirlock Agent](command:swirlock-agent.open)\n\nThe panel persists when hidden, so you can dock it, split it, or move it like any file."
      }
    ],
    "commands": [
      {
        "command": "swirlock-agent.open",
        "title": "Swirlock: Open Agent Panel",
        "icon": "resources/swirlock.svg"
      },
      {
        "command": "swirlock-agent.stop",
        "title": "Swirlock: Stop Current Run"
      },
      {
        "command": "swirlock-agent.togglePermissionMode",
        "title": "Swirlock: Toggle Permission Mode"
      },
      {
        "command": "swirlock-agent.preloadModel",
        "title": "Swirlock: Preload Model"
      },
      {
        "command": "swirlock-agent.showStatus",
        "title": "Swirlock: Show Model Status"
      },
      {
        "command": "swirlock-agent.openRunLog",
        "title": "Swirlock: Open Latest Run Log"
      }
    ],
    "configuration": {
      "title": "Swirlock Agent",
      "properties": {
        "swirlock-agent.host.baseUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "Base URL of the swirlock-llm-host service. WebSocket endpoint is upgraded from this."
        },
        "swirlock-agent.host.modelId": {
          "type": "string",
          "default": "",
          "description": "Override the host's default model. Empty string means use the host default."
        },
        "swirlock-agent.host.callerService": {
          "type": "string",
          "default": "swirlock-agent",
          "description": "Logical caller name reported to the model host."
        },
        "swirlock-agent.host.priority": {
          "type": "number",
          "default": 1,
          "description": "Numeric priority sent to the model host queue. Higher finite numbers run first."
        },
        "swirlock-agent.permissionMode": {
          "type": "string",
          "enum": [
            "normal",
            "bypass"
          ],
          "default": "bypass",
          "description": "normal enforces path jail and command allow list. bypass disables both. The deny list, iteration cap, and kill switch always apply. Default is bypass for autonomous operation; switch to normal for stricter sandboxing."
        },
        "swirlock-agent.command.allowList": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "^npm( |$)",
            "^pnpm( |$)",
            "^yarn( |$)",
            "^node( |$)",
            "^npx( |$)",
            "^bun( |$)",
            "^deno( |$)",
            "^tsc( |$)",
            "^tsx( |$)",
            "^eslint( |$)",
            "^prettier( |$)",
            "^jest( |$)",
            "^vitest( |$)",
            "^mocha( |$)",
            "^playwright( |$)",
            "^cypress( |$)",
            "^ng( |$)",
            "^vite( |$)",
            "^next( |$)",
            "^nuxt( |$)",
            "^astro( |$)",
            "^remix( |$)",
            "^webpack( |$)",
            "^rollup( |$)",
            "^esbuild( |$)",
            "^serve( |$)",
            "^http-server( |$)",
            "^pytest( |$)",
            "^python( |$)",
            "^python3( |$)",
            "^pip( |$)",
            "^pip3( |$)",
            "^poetry( |$)",
            "^uv( |$)",
            "^ruff( |$)",
            "^cargo( |$)",
            "^rustc( |$)",
            "^rustup( |$)",
            "^go( |$)",
            "^dotnet( |$)",
            "^java( |$)",
            "^mvn( |$)",
            "^gradle( |$)",
            "^ruby( |$)",
            "^bundle( |$)",
            "^rails( |$)",
            "^make( |$)",
            "^cmake( |$)",
            "^docker( |$)",
            "^docker-compose( |$)",
            "^kubectl( |$)",
            "^terraform( |$)",
            "^git( |$)",
            "^gh( |$)",
            "^ls( |$)",
            "^dir( |$)",
            "^cat( |$)",
            "^type( |$)",
            "^echo( |$)",
            "^pwd( |$)",
            "^cd( |$)",
            "^mkdir( |$)",
            "^touch( |$)",
            "^cp( |$)",
            "^mv( |$)",
            "^rm( |$)",
            "^which( |$)",
            "^where( |$)",
            "^Get-",
            "^Set-",
            "^New-Item",
            "^Test-Path",
            "^Select-String",
            "^Invoke-"
          ],
          "description": "Regex patterns. In normal mode, a command must match at least one to run. Bypass mode ignores this list."
        },
        "swirlock-agent.command.denyList": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "rm\\s+-rf\\s+/",
            "rm\\s+-rf\\s+~",
            ":\\(\\)\\s*\\{",
            "mkfs",
            "dd\\s+if=",
            "shutdown",
            "reboot",
            "Format-Volume",
            "Remove-Item\\s+.*-Recurse.*[A-Za-z]:\\\\\\s*$"
          ],
          "description": "Regex patterns. Commands matching any of these are blocked even in bypass mode."
        },
        "swirlock-agent.maxIterations": {
          "type": "number",
          "default": 50,
          "minimum": 1,
          "description": "Hard maximum number of agent loop iterations per task."
        },
        "swirlock-agent.maxContextTokens": {
          "type": "number",
          "default": 32000,
          "minimum": 2000,
          "description": "Total token budget for the assembled prompt across all three tiers (static, working state, rolling transcript)."
        },
        "swirlock-agent.budgets.projectMemoryTokens": {
          "type": "number",
          "default": 4000,
          "description": "Tier 1 cap for .swirlock/AGENT.md project memory."
        },
        "swirlock-agent.budgets.repoMapTokens": {
          "type": "number",
          "default": 1500,
          "description": "Tier 1 cap for the repo map (directory listing of source files)."
        },
        "swirlock-agent.budgets.activeFilesTokens": {
          "type": "number",
          "default": 8000,
          "description": "Tier 2 cap for the active file set (latest content of files in scope)."
        },
        "swirlock-agent.budgets.todosTokens": {
          "type": "number",
          "default": 500,
          "description": "Tier 2 cap for the TODO list."
        },
        "swirlock-agent.budgets.planTokens": {
          "type": "number",
          "default": 1000,
          "description": "Tier 2 cap for the plan."
        },
        "swirlock-agent.budgets.compactionThreshold": {
          "type": "number",
          "default": 0.75,
          "minimum": 0.5,
          "maximum": 0.95,
          "description": "Fraction of the transcript sub-budget that triggers LLM-based compaction of older middle entries."
        },
        "swirlock-agent.budgets.keepRecentTurns": {
          "type": "number",
          "default": 6,
          "minimum": 2,
          "description": "Number of recent transcript turns kept verbatim across compaction."
        },
        "swirlock-agent.shell": {
          "type": "string",
          "enum": [
            "auto",
            "pwsh",
            "powershell",
            "bash",
            "sh"
          ],
          "default": "auto",
          "description": "Shell used for run_command. auto picks per platform."
        },
        "swirlock-agent.runLog.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Write a JSONL run log to .swirlock/runs/ for each task."
        },
        "swirlock-agent.streaming.showThinking": {
          "type": "boolean",
          "default": true,
          "description": "Surface the model's thinking events in the agent panel."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "swirlock-agent.preloadModel",
          "when": "view == swirlock-agent.launcher",
          "group": "navigation@1"
        },
        {
          "command": "swirlock-agent.togglePermissionMode",
          "when": "view == swirlock-agent.launcher",
          "group": "navigation@2"
        },
        {
          "command": "swirlock-agent.openRunLog",
          "when": "view == swirlock-agent.launcher",
          "group": "1_logs"
        },
        {
          "command": "swirlock-agent.showStatus",
          "when": "view == swirlock-agent.launcher",
          "group": "1_logs"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "marked": "^15.0.12",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.95.0",
    "@types/ws": "^8.5.13",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  }
}
